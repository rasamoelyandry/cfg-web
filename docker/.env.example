# PostgreSQL
POSTGRES_DB=cfg
POSTGRES_USER=cfg
POSTGRES_PASSWORD=change_me_strong_password

# Redis
REDIS_PASSWORD=change_me_redis_password

# JWT - générer avec: openssl rand -base64 64
JWT_SECRET=change-me-generate-with-openssl-rand-base64-64
JWT_ACCESS_EXPIRY_MS=900000
JWT_REFRESH_EXPIRY_MS=604800000

# CORS (URLs frontend séparées par virgule)
CORS_ORIGINS=https://app.cfg.mg

# Nginx
DOMAIN=app.cfg.mg

# Logs
LOG_LEVEL=INFO
